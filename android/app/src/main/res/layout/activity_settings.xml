<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clay Server"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#e6edf3"
        android:layout_marginBottom="12dp" />

    <!-- Host + Port on same row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Host"
                android:textSize="12sp"
                android:textColor="#8b949e" />

            <EditText
                android:id="@+id/serverHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="hostname or IP"
                android:inputType="text"
                android:textColor="#e6edf3"
                android:textColorHint="#484f58"
                android:textSize="15sp"
                android:backgroundTint="#3fb950"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Port"
                android:textSize="12sp"
                android:textColor="#8b949e" />

            <EditText
                android:id="@+id/serverPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="9000"
                android:inputType="number"
                android:textColor="#e6edf3"
                android:textColorHint="#484f58"
                android:textSize="15sp"
                android:backgroundTint="#3fb950"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Secure toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Secure (HTTPS)"
            android:textSize="14sp"
            android:textColor="#e6edf3" />

        <Switch
            android:id="@+id/secureSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:thumbTint="#3fb950"
            android:trackTint="#8b949e" />
    </LinearLayout>

    <!-- Advanced checkbox -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/advancedCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#3fb950" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced"
            android:textSize="14sp"
            android:textColor="#e6edf3"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Advanced section -->
    <LinearLayout
        android:id="@+id/advancedSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:paddingStart="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Remote Hostname when device IP doesn't match Local Netmask."
            android:textSize="11sp"
            android:textColor="#8b949e"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Local Netmask"
            android:textSize="12sp"
            android:textColor="#8b949e"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/localNetmask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.1.*"
            android:inputType="text"
            android:textColor="#e6edf3"
            android:textColorHint="#484f58"
            android:textSize="15sp"
            android:backgroundTint="#3fb950"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remote Hostname"
            android:textSize="12sp"
            android:textColor="#8b949e"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/remoteHostname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="myhost.example.com"
            android:inputType="text"
            android:textColor="#e6edf3"
            android:textColorHint="#484f58"
            android:textSize="15sp"
            android:backgroundTint="#3fb950"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#30363d" />

    <!-- Authentication section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Authentication"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#e6edf3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Leave blank to enter on connect"
        android:textSize="11sp"
        android:textColor="#8b949e"
        android:layout_marginTop="2dp" />

    <!-- Username + Password on same row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="12sp"
                android:textColor="#8b949e" />

            <EditText
                android:id="@+id/serverUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="username"
                android:inputType="text"
                android:textColor="#e6edf3"
                android:textColorHint="#484f58"
                android:textSize="15sp"
                android:backgroundTint="#3fb950"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="12sp"
                android:textColor="#8b949e" />

            <EditText
                android:id="@+id/serverPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="password"
                android:inputType="textPassword"
                android:textColor="#e6edf3"
                android:textColorHint="#484f58"
                android:textSize="15sp"
                android:backgroundTint="#3fb950"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Auth Key display -->
    <LinearLayout
        android:id="@+id/authKeyRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auth Key"
            android:textSize="12sp"
            android:textColor="#8b949e"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/authKeyValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="none"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#7d8590"
            android:lineSpacingMultiplier="1.4"
            android:breakStrategy="simple"
            android:background="@drawable/auth_key_bg"
            android:padding="6dp"
            android:textIsSelectable="true" />
    </LinearLayout>

    <!-- Connection status -->
    <TextView
        android:id="@+id/connectionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#f85149"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:gravity="end">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#30363d"
            android:textColor="#e6edf3"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:backgroundTint="#3fb950"
            android:textColor="#000000" />
    </LinearLayout>

</LinearLayout>
</ScrollView>
